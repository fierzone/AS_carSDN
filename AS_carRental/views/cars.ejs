<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: #0f172a;
            color: #f8fafc;
            margin: 0;
            padding: 2rem;
        }

        .container {
            max-width: 800px;
            margin: 0 auto;
            background: rgba(30, 41, 59, 0.7);
            padding: 2rem;
            border-radius: 1rem;
        }

        h1 {
            color: #38bdf8;
            text-align: center;
        }

        .car-card {
            border: 1px solid rgba(255, 255, 255, 0.1);
            padding: 1rem;
            margin-bottom: 1rem;
            border-radius: 0.5rem;
            background: #1e293b;
        }

        .car-card h2 {
            margin-top: 0;
            color: #818cf8;
        }

        .status {
            font-weight: bold;
            color: #34d399;
        }

        .status.rented {
            color: #ef4444;
        }

        .status.maintenance {
            color: #fbbf24;
        }
    </style>
</head>

<body>
    <div class="container">
        <h1>
            <%= title %>
        </h1>
        <div><a href="/" style="color: #38bdf8; text-decoration: none;">&larr; Back Home</a></div>
        <br>
        <style>
            .car-grid {
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
                gap: 1.5rem;
            }

            .car-card img {
                width: 100%;
                height: 200px;
                object-fit: cover;
                border-radius: 0.5rem;
                margin-bottom: 1rem;
                border: 1px solid rgba(255, 255, 255, 0.05);
            }
        </style>
        <div class="car-grid">
            <% if (cars && cars.length> 0) { %>
                <% cars.forEach(car=> { %>
                    <div class="car-card">
                        <% if(car.image) { %>
                            <img src="/<%= car.image %>" alt="<%= car.model %>">
                            <% } %>
                                <h2>
                                    <%= car.model %> (<%= car.carNumber %>)
                                </h2>
                                <p>Status: <span class="status <%= car.status %>">
                                        <%= car.status %>
                                    </span></p>
                                <p>Capacity: <%= car.capacity %> seats</p>
                                <p>Price: <%= car.pricePerDay %> VND/day</p>
                                <p>Features: <%= car.features.join(', ') %></p>
                    <br>
                    <% if (car.status === ' available') { %>
                                        <a href="/bookings/new?carNumber=<%= encodeURIComponent(car.carNumber) %>"
                                            class="btn-book"
                                            style="display:inline-block; padding:0.5rem 1rem; background:#38bdf8; color:white; border-radius:0.375rem; text-decoration:none;">Book
                                            This Car</a>
                                        <% } else { %>
                                            <span style="color: #94a3b8; font-style: italic;">Not Available</span>
                                            <% } %>
                    </div>
                    <% }) %>
                        <% } else { %>
                            <p>No cars available at the moment.</p>
                            <% } %>
        </div>
    </div>
</body>

</html>