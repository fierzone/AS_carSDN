<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: #0f172a;
            color: #f8fafc;
            margin: 0;
            padding: 2rem;
        }

        .container {
            max-width: 800px;
            margin: 0 auto;
            background: rgba(30, 41, 59, 0.7);
            padding: 2rem;
            border-radius: 1rem;
        }

        h1 {
            color: #38bdf8;
            text-align: center;
        }

        .booking-card {
            border: 1px solid rgba(255, 255, 255, 0.1);
            padding: 1rem;
            margin-bottom: 1rem;
            border-radius: 0.5rem;
            background: #1e293b;
        }

        .booking-card h2 {
            margin-top: 0;
            color: #818cf8;
        }

        a.anchor-btn {
            color: #38bdf8;
            text-decoration: none;
            margin-bottom: 1rem;
            display: inline-block;
        }
    </style>
</head>

<body>
    <div class="container">
        <h1>
            <%= title %>
        </h1>
        <a href="/" class="anchor-btn">&larr; Back Home</a> | <a href="/cars" class="anchor-btn">View Cars & Book</a>
        <br><br>
        <% if (bookings && bookings.length> 0) { %>
            <% bookings.forEach(booking=> { %>
                <div class="booking-card">
                    <h2>Booking for <%= booking.carNumber %>
                    </h2>
                    <p><strong>Customer:</strong>
                        <%= booking.customerName %>
                    </p>
                    <p><strong>Start Date:</strong>
                        <%= new Date(booking.startDate).toLocaleDateString() %>
                    </p>
                    <p><strong>End Date:</strong>
                        <%= new Date(booking.endDate).toLocaleDateString() %>
                    </p>
                    <p><strong>Total Amount:</strong>
                        <%= booking.totalAmount.toLocaleString() %> VND
                    </p>
                </div>
                <% }) %>
                    <% } else { %>
                        <p>No bookings available at the moment.</p>
                        <% } %>
    </div>
</body>

</html>